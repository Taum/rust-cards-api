# Leave empty in dev to use same-origin requests via Vite proxy (/api -> :8234).
# Set to API origin only (scheme + host) for production static hosting (requires CORS on the API).
# Example: https://uniques-http-api-xxxxx-uc.a.run.app
VITE_API_BASE_URL=

# Vite asset base path. Use /rust-cards-api/ for this repo's GitHub Pages project site.
# Leave unset (/) for local dev.
# VITE_BASE_PATH=/rust-cards-api/
